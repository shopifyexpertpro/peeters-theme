
{{ 'featured-slider.css' | asset_url | stylesheet_tag }}

{%  render 'featured-slider' %} 





{%  schema  %} 
    {
        "name": "featured slider",
        "class": "featured-slider",
        "tag": "section",
        "blocks": [{
            "type": "image-slider",
            "name":"Image Slider",
            "settings": [
                    {
                        "type": "image_picker",
                        "id": "media",
                        "label": "Add Slider Image"
                    },
                     {
                        "type": "image_picker",
                        "id": "media_phone",
                        "label": "Slider Image For Mobile"
                    },
                    {
                        "type": "text",
                         "id": "sub_title",
                        "label": "Sub Heading",
                        "default":"VACATURE"
                    },
                     {
                        "type": "text",
                         "id": "title",
                        "label": "Title Here",
                        "default":"Wij zoeken een ervaren fietsmonteur!"
                    },
                    {
                        "type": "range",
                        "id": "title_max_width",
                        "label": "Title Max width",
                        "max": 900,
                        "min":200,
                        "step": 10,
                        "default":700,
                        "unit": "px"
                    },
                    {
                        "type": "textarea",
                         "id": "content",
                        "label": "Content",
                        "default":"Heb jij net zo’n passie voor fietsen als wij en heb je ervaring in het onderhouden, repareren en afstellen van diverse fietsen? Bekijk dan onze vacature en wie weet tot snel!"
                    },
                    {
                        "type": "range",
                        "id": "content_max_width",
                        "label": "Content Max width",
                        "max": 900,
                        "min":200,
                        "step": 10,
                        "default":500,
                        "unit": "px"
                    },
                     {
                        "type": "text",
                         "id": "btn_text",
                        "label": "Button Text",
                        "default":"BEKIJK VACATURE"
                    },
                     {
                        "type": "url",
                         "id": "btn_url",
                        "label": "Button Link"
                    },
                    {
                        "type": "checkbox",
                        "id": "icons",
                        "label": "Add Images",
                        "default":false
                    },
                    {
                        "type": "image_picker",
                        "id": "icon_01",
                        "label": "Add ICON 01",
                        "visible_if": "{{ block.settings.icons }}"
                    },
                    {
                        "type": "image_picker",
                        "id": "icon_02",
                        "label": "Add ICON 02",
                        "visible_if": "{{ block.settings.icons }}"
                    },
                    {
                        "type": "image_picker",
                        "id": "icon_03",
                        "label": "Add ICON 03",
                        "visible_if": "{{ block.settings.icons }}"
                    },
                    {
                        "type": "image_picker",
                        "id": "icon_04",
                        "label": "Add ICON 04",
                        "visible_if": "{{ block.settings.icons }}"
                    },
                    {
                        "type": "image_picker",
                        "id": "icon_05",
                        "label": "Add ICON 05",
                        "visible_if": "{{ block.settings.icons }}"
                    },
                    {
                        "type": "image_picker",
                        "id": "icon_06",
                        "label": "Add ICON 06",
                        "visible_if": "{{ block.settings.icons }}"
                    },
                    {
                        "type": "image_picker",
                        "id": "icon_07",
                        "label": "Add ICON 07",
                        "visible_if": "{{ block.settings.icons }}"
                    },
                    {
                        "type": "text",
                        "id":"bottom_text",
                        "label": "*Short Text",
                        "default":"*Zolang de voorraad strekt"
                    },
                    {
                        "type": "checkbox",
                        "id": "badge",
                        "label": "Add Badge",
                        "default":false
                    },
                    {
                        "type": "image_picker",
                        "id": "badge_image",
                        "label": "Add Image",
                        "visible_if": "{{ block.settings.badge }}"
                    },
                   
                    {
                        "type": "inline_richtext",
                        "id": "badge_text",
                        "label": "Badge Text",
                        "default": "GRATIS KINDERZITJE + GOUD PAKKET T.W.V. €225",
                        "visible_if": "{{ block.settings.badge }}"

                    },
                    {
                        "type": "range",
                        "id": "badge_width",
                        "label": "Badge_width",
                        "max": 300,
                        "min": 0,
                        "step": 5,
                        "default":240,
                        "unit": "px",
                        "visible_if": "{{ block.settings.badge }}"
                    },
                    {
                        "type": "range",
                        "id": "vertical",
                        "label": "Position Vertical",
                        "max": 100,
                        "min": 0,
                        "step": 1,
                        "default":100,
                        "unit": "%",
                        "visible_if": "{{ block.settings.badge }}"
                    },
                     {
                        "type": "range",
                        "id": "horizontal",
                        "label": "Position Horizontal",
                        "max": 100,
                        "min": 0,
                        "step": 1,
                        "default":50,
                        "unit": "%",
                        "visible_if": "{{ block.settings.badge }}"
                    },
                    {
                        "type": "header",
                        "content": "Mobile Style of Badge",
                        "visible_if": "{{ block.settings.badge }}"
                    },
                    {
                        "type": "range",
                        "id": "badge_width_phone",
                        "label": "Badge Width in Phone",
                        "max": 300,
                        "min": 0,
                        "step": 5,
                        "default":200,
                        "unit": "px",
                        "visible_if": "{{ block.settings.badge }}"
                    },
                    {
                        "type": "range",
                        "id": "vertical_phone",
                        "label": "Position Vertical in phone",
                        "max": 100,
                        "min": 0,
                        "step": 1,
                        "default":100,
                        "unit": "%",
                        "visible_if": "{{ block.settings.badge }}"
                    },
                     {
                        "type": "range",
                        "id": "horizontal_phone",
                        "label": "Position Horizontal in Phone",
                        "max": 100,
                        "min": 0,
                        "step": 1,
                        "default":50,
                        "unit": "%",
                        "visible_if": "{{ block.settings.badge }}"
                    },

                 
                    {
                    "type": "color_scheme",
                    "id": "color_scheme",
                    "label": "settings.color_scheme",
                    "default": "scheme-5"
                     }

                    
                
            ]
        }],
        "settings": [
            {
                "type": "header",
                "content": "Section Style"
            },
            {
                "type": "text",
                "id": "layout_max_width",
                "label": "Layout Max Width",
                "default":"1603px"
            },
            {
                "type": "color_scheme",
                "id": "color_scheme",
                "label": "settings.color_scheme",
                "default": "scheme-1"
            },
            {
                "type": "range",
                "id": "padding_top",
                "label": "Padding Top",
                "max": 100,
                "min": 0,
                "step": 5,
                "default":20,
                "unit": "px"
            },
             {
                "type": "range",
                "id": "padding_bottom",
                "label": "Padding Bottom",
                "max": 100,
                "min": 0,
                "step": 5,
                "default":20,
                "unit": "px"
            }
        ],
        "presets": [
            {
            "name": "featured slider"
        }]
    }
{% endschema %} 
